---
import type { CollectionEntry } from 'astro:content'
import type { ImageMetadata } from 'astro';

import { getEntry, render } from 'astro:content';
import { getImage } from 'astro:assets';
import CardFrame from '@components/deckyard/CardFrame.astro';

interface Props {
  card: CollectionEntry<"cards">;
  id?: string;
  number?: number;
}

const {
  card,
  id = undefined,
  number = undefined,
} = Astro.props;

const deck = card.data.deck?.reference && await getEntry(card.data.deck?.reference);

// TODO: Move background support to library function
// Calculate background
async function getBackgroundUrl(image: ImageMetadata | undefined) {
  if (image === undefined)
    return undefined;

  const optimizedImg = await getImage({ src: image, format: 'png'});
  return optimizedImg.src;
}

const deckBackgroundImage = await getBackgroundUrl(
  card.data.background?.image || deck?.data.background?.image);

// const deckBackgroundSize = card.data.background?.imageSize || deck?.data.background?.imageSize;
const bleed = card.data.background?.bleed || deck?.data.background?.bleed;

function getBackgroundStyle() {
  if (deckBackgroundImage) {
    const backgrounds = [
      deck?.data.background?.gradient,
      `no-repeat url(${deckBackgroundImage})`,
      deck?.data.background?.color,
    ].filter(x => x)
    return `${backgrounds.join(', ')}`;
  }
  return ''
}
const { Content } = await render(card);

// TODO: Change this to be slot-based
---

<CardFrame
  {id}
  background={getBackgroundStyle()}
  size={deck?.data.dimensions.size}
  landscape={deck?.data.dimensions.landscape}
  card-number={number}
  {bleed}
>
  <Content />
</CardFrame>
