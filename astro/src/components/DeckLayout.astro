---
import type { CollectionEntry } from 'astro:content';
import { getCollection, getEntry, render } from 'astro:content';

async function getDeckAndContent(deckId?: string) {
  if (deckId) {
    const deck = await getEntry("decks", deckId);
    if (deck === undefined) {
      throw new Error(`Could not find deck '${deckId}'`);
    } else {
      const { Content: DeckContent } = await render(deck) || { Content: 'div' };
      return { deck, DeckContent }
    }
  }
  return { "DeckContent": Fragment };
}

interface Props {
  deck?: CollectionEntry<"decks">["id"];
  landscape ?: boolean;
}
type BackTypes = "horizontal" | "horizontal-print" | "vertical" | "vertical-print"

const { deck: deckId = undefined, landscape = undefined } = Astro.props;
const { deck, DeckContent } = await getDeckAndContent(deckId);
const back: BackTypes = deck?.data.pages.deck?.back ?? "vertical-print"

const cards: CollectionEntry<"cards">[] = await getCollection(
  "cards", ({ data }) => deckId ? data.deck?.reference?.id === deckId : !!data.deck?.reference
);
cards.sort((a, b) => {
  const aDeckId = a.data.deck?.reference?.id ?? "";
  const bDeckId = b.data.deck?.reference?.id ?? "";
  if (aDeckId < bDeckId) return -1;
  else if (aDeckId > bDeckId) return 1;
  else {
    if (a.data.title < b.data.title) return -1;
    else if (b.data.title < a.data.title) return 1;
  }
  return 0;
});

interface DeckList {
  card: CollectionEntry<"cards">;
  cardIndex: number; // Index of card when duplicates
  deckIndex: number;
}

const deckListGroupedByCards: DeckList[] = cards.map(
  (card) => Array.from(
    {length: card.data.deck?.quantity ?? 1},
    (_, cardIndex) => ({ card, cardIndex,})
  )
).flat().map(
  (d, index) => ({deckIndex: index + 1, ...d})
);

function getCardIdSuffix(index: number) {
  return index ? `-${index + 1}` : '';
}

// TODO: Decide how we can make this more generic so this can be in Deckyard.
import CardLayout from '@components/deckyard/CardFrontAndBack.astro';
// import CardLayout from '@components/deckyard/CardLayout.astro';
---
<div id={`deck-${deck?.id}`} class="deck">
  <DeckContent />
  <div class="card-list not-content" data-theme="light">
    { deckListGroupedByCards.map(({card, cardIndex, deckIndex: number}) =>
      deck?.data.pages?.card
      ? // TODO: Change to config.base when this becomes an integration.
        <a class="card-link" href={`${import.meta.env.BASE_URL}/components/cards/${card.id}/`}>
          <CardLayout
            id={`card-${card.id}${getCardIdSuffix(cardIndex)}`}
            {card}
            {number}
            back={back === "horizontal-print" || back === "vertical-print" ? "print" : "both"}
            vertical={back === "vertical" || back === "vertical-print"}
          />
        </a>
      : <CardLayout
          id={`card-${card.id}${getCardIdSuffix(cardIndex)}`}
          {card}
          {number}
          back={back === "horizontal-print" || back === "vertical-print" ? "print" : "both"}
          vertical={back === "vertical" || back === "vertical-print"}
        />
    )}
  </div>
</div>

<style>
.card-list {
  width: 100%;

  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  align-content: center;

  /* TODO: Add print variables in deckyard.css */
  @media print {
    gap: 0;
    break-before: page;
    break-after: page;

    vertical-align: middle;
    /* width: 100vw;
    height: 100vh; */
  }

  @media screen {
    gap: 0.75em;
  }
}

.card-link {
  text-decoration: none;
  color: inherit;
  display: block;
}

</style>
