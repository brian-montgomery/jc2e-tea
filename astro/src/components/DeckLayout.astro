---
import type { CollectionEntry, CollectionKey } from 'astro:content';
// TODO: import type { DefaultCardSchema } from "src/lib/content";

import { getCollection, getEntry, render } from 'astro:content';

interface Props {
  deck: CollectionEntry<"decks">["id"];
}

const { deck: deckId } = Astro.props;
const deck = await getEntry("decks", deckId);

if (deck === undefined)
  throw new Error(`Could not find deck '${deckId}'`);

// TODO: Type it so that CardCollection refers to DefaultCardSchema.
// @ts-ignore
const cardCollection: CollectionKey = deck.data.cardCollection;
const cards: CollectionEntry<typeof cardCollection>[] = await getCollection(
  // @ts-ignore
  cardCollection, ({ data }) => data.deck?.id == deckId
)
cards.sort((a, b) => {
  // @ts-ignore
  if (a.data?.title < b.data?.title) return -1;
  // @ts-ignore
  else if (b.data.title < a.data.title) return 1;
  return 0;
});

interface DeckList {
  card: CollectionEntry<typeof cardCollection>;
  cardIndex: number; // Index of card when duplicates
  deckIndex: number;
}

const deckListGroupedByCards: DeckList[] = cards.map(
  (card) => Array.from(
    // @ts-ignore
    {length: card.data.quantity ?? 1},
    (_, cardIndex) => ({ card, cardIndex,})
  )
).flat().map(
  (d, index) => ({deckIndex: index + 1, ...d})
);

const { Content: DeckContent } = await render(deck);

function getCardIdSuffix(index: number) {
  return index ? `-${index + 1}` : '';
}

// TODO: Decide how we can make this more generic so this can be in Deckyard.
import CardLayout from '@components/deckyard/CardLayout.astro';
---
<div id={`deck-${deck?.id}`} class="deck">
  <DeckContent />
  <div class="card-list" data-theme="light">
    {
      deckListGroupedByCards.map(({card, cardIndex, deckIndex: number}) => (
        <a class="card-link" href={`/jc2e-tea/decks/${deck.id}/cards/${card.id}/`}>
          <CardLayout id={`card-${card.id}${getCardIdSuffix(cardIndex)}`} {card} {deck} {number} />
        </a>
      ))
    }
  </div>
</div>

<style>
.card-list {
  width: 100%;

  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  align-content: center;

  /* TODO: Add print variables in deckyard.css */
  @media print {
    gap: 0;
    break-before: page;
    break-after: page;

    vertical-align: middle;
    /* width: 100vw;
    height: 100vh; */
  }

  @media screen {
    gap: 0.75em;
  }
}

.card-link {
  text-decoration: none;
  color: inherit;
  display: block;
}

</style>
