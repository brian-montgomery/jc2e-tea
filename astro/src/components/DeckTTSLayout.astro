---
import type { CollectionEntry } from 'astro:content';
import { getCollection, getEntry, render } from 'astro:content';

interface Props {
  deck?: CollectionEntry<"decks">["id"];
  landscape ?: boolean;
  class ?: string;
}

const { deck: deckId = undefined, landscape = undefined, class: cssClass = "" } = Astro.props;
if (deckId === undefined) {
  throw new Error(`Could not find deck '${deckId}'`);
}
const corners = false;
const deck = await getEntry("decks", deckId);
if (deck === undefined) {
  throw new Error(`Could not find deck '${deckId}'`);
}

const combined = ["office", "scenario"];
const cards: CollectionEntry<"cards">[] = await getCollection(
  "cards", ({ data }) =>
    combined.includes(deckId)
    ? combined.includes(data.deck?.reference?.id)
    : data.deck?.reference?.id === deckId
);
cards.sort((a, b) => {
  const aDeckId = a.data.deck?.reference?.id ?? "";
  const bDeckId = b.data.deck?.reference?.id ?? "";
  if (aDeckId < bDeckId) return -1;
  else if (aDeckId > bDeckId) return 1;
  else {
    if (a.data.title < b.data.title) return -1;
    else if (b.data.title < a.data.title) return 1;
  }
  return 0;
});

interface DeckList {
  card: CollectionEntry<"cards">;
  cardIndex: number; // Index of card when duplicates
  deckIndex: number;
}

const deckListGroupedByCards: DeckList[] = cards.map(
  (card) => Array.from(
    {length: card.data.deck?.quantity ?? 1},
    (_, cardIndex) => ({ card, cardIndex,})
  )
).flat().map(
  (d, index) => ({deckIndex: index + 1, ...d})
);

function getCardIdSuffix(index: number) {
  return index ? `-${index + 1}` : '';
}

import CardBack from '@components/deckyard/CardBack.astro';
import CardFront from '@components/deckyard/CardLayout.astro';
---
<div id={`deck-${deck?.id ?? 'tts'}`} class:list={["deck", cssClass]}>
  <div class="card-list not-content" data-theme="light">
    { deckListGroupedByCards.map(({card, cardIndex, deckIndex: number}) =>
      <CardFront
          id={`card-${card.id}${getCardIdSuffix(cardIndex)}`}
          {card}
          {number}
          {corners}
        />
    )}
  </div>
  <hr class="break"/>
  <div class="card-list not-content" data-theme="light">
    { deckListGroupedByCards.map(({card, cardIndex}) =>
      <CardBack
          id={`card-back-${card.id}${getCardIdSuffix(cardIndex)}`}
          {card}
          {corners}
        />
    )}
  </div>
</div>

<style>
.card-list {
  width: 100%;

  display: flex;
  flex-wrap: wrap;
  justify-content: start;
  align-items: center;
  align-content: center;

  gap: 0;
  margin: 2rem 0;

  /* TODO: Add print variables in deckyard.css */
  @media print {
    break-before: page;
    break-after: page;

    vertical-align: middle;
    /* width: 100vw;
    height: 100vh; */
  }
}

</style>
