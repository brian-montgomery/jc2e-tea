---
import type { I18nKeys } from 'node_modules/@astrojs/starlight/utils/createTranslationSystem';

interface Props {
  key?: I18nKeys;
}

const text: I18nKeys | undefined = Astro.slots.has('default') ?
  (await Astro.slots.render('default')) as I18nKeys : undefined;
const { key = text } = Astro.props;
---

<Fragment set:text={key && Astro.locals.t(key)} />
