---
interface Props {
  title: string;
  shortTitle?: boolean,
  heading?: "dilemma" | "special" | "reference" | undefined;
  textSize?: number,
  regions?: string[],
  tags?: string[],
}

const {
  heading = undefined,
  title,
  shortTitle = false,
  textSize = 100,
  regions = "",
  tags = [],
} = Astro.props;

import CardNumber from '@components/deckyard/CardNumber.astro';
---

<div class="column">
  {
    heading && (
      <div class="heading">
        <slot name="heading" />
      </div>
    )
  }
  <h2 class:list={[{shortTitle,}]} id={title}>{ title }</h2>
  <div class:list={["main-text"]} style={`--text-size: ${textSize}%`}>
    <slot></slot>
  </div>
  <div class="footer">
    <div class="number">
      { tags.includes('duty') && "CD" }
      <CardNumber />
    </div>
    { !!regions && (
      <ul class="regions">
        {regions.map((r) => (<li><span set:text={r} /></li>))}
      </ul>
    )}
  </div>
</div>

<style>
  .heading {
    border-top: 3px double black;
    border-bottom: 3px double black;
    margin-bottom: 0.2em;
    width: 100%;
  }
  .column {
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    align-items: center;
    align-content: center;
    height: 100%;
    padding: 0.5em 1em;

    color: black;

    /* Debug flex layout.
    & > :global(*) {
      border: 1px solid lightblue;
    } */
  }
  h2 {
    font-family: 'Libre Bodoni Variable', serif;
    /* font-family: 'Baskervville Variable', serif; */
    letter-spacing: 1px;
    font-weight: 700;
    font-size: 1.25em;
    text-transform: uppercase;
    line-height: 1.2em;
    padding: 0.25em 0;
    justify-self: end;
    text-align: center;
    vertical-align: bottom;
  }
  .heading + h2 {
    font-size: 1.15em;
    letter-spacing: 0.5px;
    padding: 0.25em 0;
  }
  h2.shortTitle {
    padding: 0.75em 0;
  }
  .main-text {
    flex-grow: 1;

    display: flex;
    flex-direction: column;
    justify-content: center;

    & :global(p) {
      font-family: 'Baskervville Variable';
      font-size: var(--text-size);
      line-height: 1.25em;
      text-align: center;
      margin-bottom: 0.75em;
    }
    & :global(strong) {
      font-weight: 600;
    }
  }
  .footer {
    align-self: stretch;

    display: flex;
    flex-direction: row-reverse;
    justify-content: space-between;

    margin-right: -0.25em;

    .number {
      font-size: 0.7em;
      align-self: flex-end;
      justify-self: flex-end;
    }
    .regions {
      list-style: none;
      margin: 0;
      padding: 0;

      li {
        display: inline-block;
        width: 2em;
        height: 2em;

        font-family: 'Libre Bodoni Variable', serif;
        font-weight: 600;
        font-size: 85%;
        text-align: center;

        border: 1pt solid black;
        background: #A4582B;
        color: white;
        margin-right: 0.25em;

        span {
          vertical-align: middle;
        }
      }
    }
  }
  .footer:has(.regions) {
    padding-top: 0.25em;
    border-top: 1px solid lightgray;
  }
</style>