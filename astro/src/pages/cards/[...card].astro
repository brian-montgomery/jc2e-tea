---
import { getCollection, render, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const cards = await getCollection("cards");

  return Promise.all(cards.map(async (card) => {
    const { Content } = await render(card);

    return ({
      params: { card: card.id, },
      props: {
        card,
        page: {
          // hasSidebar: true,
          frontmatter: {
            title: card.data.title,
            tableOfContents: false,
            template: 'splash',
            pagefind: true,
            prev: false,
            next: false,
            hero: {
              tagline: card.data.description,
              image: {
                html: "<div></div>",
              }
            }
          },
        },
      },
    });
  }));
}

import StarlightPage, { type StarlightPageProps } from '@astrojs/starlight/components/StarlightPage.astro';

interface Props {
  card: CollectionEntry<"cards">;
  page: StarlightPageProps;
}

const { card, page, } = Astro.props;
const { background, dimensions, deck } = card.data;
const { landscape } = await getCardStyles(background, dimensions, deck);

import CardDetails from "@components/CardDetails.astro";
import CardFrontAndBack from "@components/deckyard/CardFrontAndBack.astro";
import { getCardStyles } from "src/lib/card-styling";
---

<StarlightPage {...page}>
  <CardDetails {card} />
  <CardFrontAndBack id="hero-card" class="load" {card} gap vertical={landscape} />
</StarlightPage>

<!-- TODO: Move Script to Card Details to better interact with Splash Template -->
<style>
  #hero-card {
    transform: scale((1, 1));
    transform-origin: left;

    &.load {
      display: none;
    }
  }
</style>

<script>
addEventListener("load", () => {
  const heroWrapper = document.querySelector(".hero-html");
  const heroCard = document.getElementById("hero-card");

  function resize() {
    heroCard!.style.transform = 'scale(1, 1)';
    heroCard!.classList.remove("load");

    const { width: cw, height: ch } = heroCard!.getBoundingClientRect();
    const { width: ww, height: wh } = heroWrapper!.getBoundingClientRect();
    console.log(cw, ch, ww, wh);

    const scaleAmount = Math.min(ww / cw, wh / ch);
    heroCard!.style.transform = `scale(${scaleAmount}, ${scaleAmount})`;
  }

  if (heroCard && heroWrapper) {
      // const parent = heroCard.parentNode;
      heroWrapper.appendChild(heroCard);
      resize();
  }

  addEventListener("resize", resize)
});
</script>
