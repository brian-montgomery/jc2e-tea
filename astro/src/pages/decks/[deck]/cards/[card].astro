---
import type { CollectionEntry } from "astro:content";

import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const decks = await getCollection("decks");
  const nestedArrays = await Promise.all(decks.map(
    async (deck) => {
      const { cardCollection } = deck.data;
      // @ts-ignore
      const cards = await getCollection(
        "cards", ({ data }) => data.deck?.id === deck.id);

      return cards.map((card) => ({
        params: { deck: deck.id, card: card.id, },
        props: {
          deck,
          card,
          page: {
            hasSidebar: true,
            frontmatter: {
              title: `${card.data.title}`,
              tableOfContents: false,
              pagefind: true,
              prev: false,
              next: false,
            },
          },
        },
      }));
    }
  ));
  return nestedArrays.flat();
}

const { deck, card, page, } = Astro.props;

import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import CardDetails from "@components/CardDetails.astro";
---

<StarlightPage {...page}>
  <CardDetails {card} {deck} />
</StarlightPage>